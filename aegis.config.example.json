{
  "data_dir": "./data",
  "skills_dir": "./skills",
  "budget": {
    "daily_token_limit": 100000,
    "reserve_for_owner": 20000,
    "notify_session_id": "tg:YOUR_CHAT_ID"
  },
  "schedules": [
    {
      "id": "morning-digest",
      "cron": "07:00",
      "text": "/digest",
      "session_id": "tg:YOUR_CHAT_ID"
    }
  ],
  "learning": {
    "self_improvement_llm_enabled": false,
    "min_reuse_rate": 0,
    "memory_consolidation_enabled": false,
    "consolidation_batch_size": 25,
    "research_deep_enabled": false,
    "research_deep_branch_count": 3,
    "research_deep_token_cap": 12000
  },
  "memory": {
    "context": {
      "enabled": true,
      "dialog_tail": 10,
      "recall_k": 3,
      "max_tokens": 2048
    }
  },
  "web": {
    "max_response_kb": 512,
    "cache_ttl_s": 3600,
    "broker_host": "aegis-broker:8080"
  },
  "sandbox": {
    "workspace_dir": "./workspace",
    "runtime": "docker"
  },
  "mcp": {
    "servers": []
  },
  "llm": {
    "p_llm": {
      "base_url": "http://localhost:11434/v1",
      "model": "qwen3:14b",
      "key_ref": "AEGIS_P_LLM_KEY",
      "max_tokens": 4096
    },
    "q_llm": {
      "base_url": "http://localhost:11434/v1",
      "model": "qwen3:14b",
      "key_ref": "AEGIS_Q_LLM_KEY",
      "max_tokens": 2048
    }
  },
  "telegram": {
    "bot_token_ref": "AEGIS_TG_BOT_TOKEN",
    "pairing_code_ref": "AEGIS_TG_PAIRING_CODE",
    "poll_timeout_s": 30
  },
  "discord": {
    "bot_token_ref": "AEGIS_DISCORD_BOT_TOKEN",
    "pairing_code_ref": "AEGIS_DISCORD_PAIRING_CODE"
  },
  "email": {
    "session_id": "email:inbox",
    "poll_interval_s": 60
  }
}
